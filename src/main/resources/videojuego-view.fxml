<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucv.lab12.controller.VideojuegoController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
    </padding>

    <Label text="Gestión de Videojuegos" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="ID Videojuego:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtId" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Consola:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="txtConsola" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Género:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="txtGenero" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Clasificación:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txtClasificacion" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Descripción:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="txtDescripcion" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="ID Desarrollador:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="txtIdDesarrollador" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <Label text="ID Distribuidor:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextField fx:id="txtIdDistribuidor" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Registrar" onAction="#onBtnRegistrarClick" style="-fx-background-color: #28a745; -fx-text-fill: white;"/>
        <Button text="Limpiar" onAction="#onBtnLimpiarClick"/>
    </HBox>

    <TableView fx:id="tblVideojuegos" prefHeight="200.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="120"/>
            <TableColumn fx:id="colConsola" text="Consola" prefWidth="80"/>
            <TableColumn fx:id="colGenero" text="Género" prefWidth="80"/>
            <TableColumn fx:id="colClasificacion" text="Clasif." prefWidth="60"/>
            <TableColumn fx:id="colIdDistribuidor" text="ID Dist." prefWidth="60"/>
        </columns>
    </TableView>
</VBox>