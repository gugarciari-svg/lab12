<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.DistribuidorFormController"
      spacing="14"
      style="-fx-padding:24; -fx-background-color:white;"
      prefWidth="460">

    <!-- Título -->
    <Label fx:id="lblTitulo" text="Distribuidor"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#1565C0;">
        <font><Font size="20.0"/></font>
    </Label>
    <Separator/>

    <!-- Formulario -->
    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="130" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="240"/>
        </columnConstraints>

        <!-- Razón Social -->
        <Label text="Razón Social: *" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-weight:bold;"/>
        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtRazonSocial" promptText="Ingrese razón social…" maxWidth="Infinity"/>
            <Label fx:id="lblRazonSocialError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <!-- RUC -->
        <Label text="RUC:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtRuc" promptText="Ingrese RUC…"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <!-- Teléfono -->
        <Label text="Teléfono:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTelefono" promptText="Ingrese teléfono…"
                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <!-- Email -->
        <Label text="Email:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="2">
            <TextField fx:id="txtEmail" promptText="Ingrese email…" maxWidth="Infinity"/>
            <Label fx:id="lblEmailError" text=""
                   style="-fx-text-fill:#C62828; -fx-font-size:11;" visible="false"/>
        </VBox>

        <!-- Dirección -->
        <Label text="Dirección:" GridPane.rowIndex="4" GridPane.columnIndex="0"
               GridPane.valignment="TOP"/>
        <TextArea fx:id="txtDireccion" promptText="Ingrese dirección…"
                  GridPane.rowIndex="4" GridPane.columnIndex="1"
                  prefHeight="72" wrapText="true"/>

        <!-- Activo -->
        <Label text="Activo:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <CheckBox fx:id="chkActivo" selected="true"
                  GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <Label text="(*) Campo obligatorio"
           style="-fx-font-size:11; -fx-text-fill:#757575;"/>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar"
                prefWidth="100"
                style="-fx-cursor:hand;"/>
        <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardar"
                defaultButton="true" prefWidth="100"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>

</VBox>
